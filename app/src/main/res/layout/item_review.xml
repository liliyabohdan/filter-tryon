<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Reviewer avatar — circular -->
    <ImageView
        android:id="@+id/ivReviewerAvatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:scaleType="centerCrop"
        android:background="@color/backgroundSecondary"
        android:contentDescription="Reviewer avatar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Reviewer name -->
    <TextView
        android:id="@+id/tvReviewerName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/textPrimary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginStart="10dp"
        app:layout_constraintTop_toTopOf="@id/ivReviewerAvatar"
        app:layout_constraintStart_toEndOf="@id/ivReviewerAvatar"
        app:layout_constraintEnd_toStartOf="@id/rbReviewRating" />

    <!-- Star rating — read-only -->
    <RatingBar
        android:id="@+id/rbReviewRating"
        style="?android:attr/ratingBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:numStars="5"
        android:stepSize="0.5"
        android:isIndicator="true"
        android:progressTint="@color/colorPrimary"
        app:layout_constraintTop_toTopOf="@id/ivReviewerAvatar"
        app:layout_constraintBottom_toBottomOf="@id/ivReviewerAvatar"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Review comment — collapsed to 2 lines by default.
        TODO: Expand/collapse review text (wire up in ReviewAdapter — see header)
    -->
    <TextView
        android:id="@+id/tvReviewText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/textSecondary"
        android:textSize="13sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginStart="10dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvReviewerName"
        app:layout_constraintStart_toEndOf="@id/ivReviewerAvatar"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        "more" / "less" toggle.
        Hidden if review text fits within 2 lines.
        TODO: Expand/collapse review text (wire up in ReviewAdapter — see header)
    -->
    <TextView
        android:id="@+id/tvReadMore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/read_more"
        android:textColor="@color/textGold"
        android:textSize="13sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        android:layout_marginStart="10dp"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/tvReviewText"
        app:layout_constraintStart_toEndOf="@id/ivReviewerAvatar" />

    <!-- Subtle divider between reviews -->
    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/dividerLight"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvReadMore"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>