<!--
    activity_shop.xml — Layout for the Shop screen
    ================================================
    Colors:  res/values/colors.xml
             (C:\Users\Admin\StudioProjects\305\app\src\main\res\values\colors.xml)

    STRUCTURE:
    - Top bar     : hamburger menu (left) + username (center)
    - Search bar  : with search icon + filter icon (right)
    - RecyclerView: scrollable list of market items (1 column)
    - Filter popup: dialog fragment (separate file — fragment_filter_dialog.xml)

    ADDING LOGIC LATER:
    - Hamburger menu      : find "TODO: Open navigation drawer / menu"
    - Username from DB    : find "TODO: Load username from DB"
    - Search logic        : find "TODO: Implement search logic"
    - Filter dialog open  : find "TODO: Open filter dialog"
    - Load items from DB  : find "TODO: Fetch market items from DB"
    - View button click   : find "TODO: Navigate to activity_item_card" (in Adapter)
    - Star rating tap     : find "TODO: Show average rating tooltip" (in Adapter)

    VIEW IDs:
    - @+id/btnMenu       — hamburger ImageButton (top-left)
    - @+id/tvUsername    — username TextView (top-center)
    - @+id/etSearch      — search EditText
    - @+id/ivSearch      — search icon
    - @+id/ivFilter      — filter icon (top-right, opens filter dialog)
    - @+id/rvShopItems   — RecyclerView (scrollable item list)

    RELATED FILES:
    - res/layout/item_shop.xml           — single item card layout (see bottom comment)
    - res/layout/fragment_filter_dialog.xml — filter popup layout (see bottom comment)
-->

<androidx.drawerlayout.widget.DrawerLayout android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/backgroundPrimary"
        tools:context=".ShopActivity"
        tools:ignore="HardcodedText">

        <!-- ══════════════════════════════════════
             TOP BAR
             ══════════════════════════════════════ -->

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:background="@null"
            android:src="@drawable/menu_icon"
            app:tint="@color/textPrimary"
            android:scaleType="centerInside"
            android:contentDescription="Menu"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/tvUsername"/>

        <!--
            Username — pulled from DB.
            TODO: Load username from DB
            In your Activity:
                TextView tvUsername = findViewById(R.id.tvUsername);
                tvUsername.setText(currentUser.getDisplayName()); // replace with your DB call
        -->
        <TextView
            android:id="@+id/tvUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textColor="@color/textPrimary"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="Johanna Doe"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ══════════════════════════════════════
             SEARCH BAR + FILTER ICON
             ══════════════════════════════════════ -->

        <androidx.cardview.widget.CardView
            android:id="@+id/cardSearch"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/backgroundSecondary"
            app:layout_constraintTop_toBottomOf="@id/tvUsername"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ivFilter">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!--
                    Search input.
                    TODO: Implement search logic
                    In your Activity:
                        EditText etSearch = findViewById(R.id.etSearch);
                        etSearch.addTextChangedListener(new TextWatcher() {
                            public void onTextChanged(CharSequence s, int start, int before, int count) {
                                // filter your item list and notify adapter
                            }
                            public void beforeTextChanged(CharSequence s, int start, int count, int after) {}
                            public void afterTextChanged(Editable s) {}
                        });
                -->
                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:hint="@string/hint_search"
                    android:textColorHint="@color/textMuted"
                    android:textColor="@color/textPrimary"
                    android:textSize="14sp"
                    android:background="@null"
                    android:paddingStart="14dp"
                    android:paddingEnd="8dp"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:singleLine="true"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/ivSearch"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <ImageView
                    android:id="@+id/ivSearch"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="14dp"
                    android:contentDescription="Search Icon"
                    android:src="@drawable/search_icon"
                    app:tint="@color/iconTint"
                    android:scaleType="centerInside"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>



        <!--
            Filter icon — opens the filter dialog.
            TODO: Open filter dialog
            In your Activity:
                ImageView ivFilter = findViewById(R.id.ivFilter);
                ivFilter.setOnClickListener(v -> {
                    FilterDialogFragment dialog = new FilterDialogFragment();
                    dialog.show(getSupportFragmentManager(), "FilterDialog");
                });
        -->
        <ImageView
            android:id="@+id/ivFilter"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="16dp"
            android:src="@drawable/filter_icon"
            app:tint="@color/textPrimary"
            android:clickable="true"
            android:focusable="true"
            android:scaleType="centerInside"
            android:contentDescription="Filter"
            app:layout_constraintTop_toTopOf="@id/cardSearch"
            app:layout_constraintBottom_toBottomOf="@id/cardSearch"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Gold accent line below search bar -->
        <View
            android:id="@+id/dividerSearch"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="8dp"
            android:background="@color/divider"
            app:layout_constraintTop_toBottomOf="@id/cardSearch"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ══════════════════════════════════════
             SHOP ITEMS LIST (RecyclerView)
             ══════════════════════════════════════
             Single-column list. Each card is rendered by item_shop.xml.
             TODO: Fetch market items from DB
             In your Activity:
                 RecyclerView rvShopItems = findViewById(R.id.rvShopItems);
                 rvShopItems.setLayoutManager(new LinearLayoutManager(this));
                 // fetch items from DB, then:
                 rvShopItems.setAdapter(new ShopAdapter(itemList));
        -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvShopItems"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            android:clipToPadding="false"
            android:paddingBottom="16dp"
            tools:listitem="@layout/item_shop"
            app:layout_constraintTop_toBottomOf="@id/dividerSearch"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        app:headerLayout="@layout/nav_header"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

</androidx.drawerlayout.widget.DrawerLayout>
