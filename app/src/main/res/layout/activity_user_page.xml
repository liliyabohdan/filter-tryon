<?xml version="1.0" encoding="utf-8"?>


<androidx.drawerlayout.widget.DrawerLayout
    android:id="@+id/drawerLayout"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/backgroundPrimary"
        android:fillViewport="true"
        android:id="@+id/main"
        tools:context=".UserPageActivity"
        tools:ignore="HardcodedText">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="28dp"
            android:paddingTop="56dp"
            android:paddingEnd="28dp"
            android:paddingBottom="40dp">

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="12dp"
                android:layout_marginTop="3dp"
                android:background="@null"
                android:contentDescription="Menu"
                android:scaleType="centerInside"
                android:src="@drawable/menu_icon"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.0"
                app:tint="@color/textPrimary" />

            <ImageView
                android:id="@+id/ivPFP"
                android:layout_width="152dp"
                android:layout_height="139dp"
                android:scaleType="centerCrop"
                android:src="@drawable/logo"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.12"
                android:text="@string/placeholder_email_display"
                android:textColor="@color/textGold"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                android:gravity="center"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvUsername" />

            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="200dp"
                android:layout_height="35dp"
                android:layout_marginTop="20dp"
                android:text="@string/placeholder_username_display"
                android:textColor="@color/textPrimary"
                android:textSize="25sp"
                android:textStyle="bold"
                android:gravity="center"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ivPFP" />

            <TextView
                android:id="@+id/tvEmailLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_marginTop="8dp"
                android:letterSpacing="0.08"
                android:text="@string/label_new_email"
                android:textColor="@color/colorPrimary"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"

                app:layout_constraintTop_toBottomOf="@id/dividerUsername" />

            <EditText
                android:id="@+id/etChangeEmail"
                android:layout_width="0dp"
                android:layout_height="35dp"
                android:layout_marginStart="5dp"
                android:layout_marginTop="8dp"
                android:background="@null"
                android:hint="@string/hint_example_email"
                android:inputType="textEmailAddress"
                android:paddingStart="0dp"
                android:paddingEnd="40dp"
                android:paddingBottom="8dp"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textMuted"
                android:textSize="15sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnChangeEmail"
                app:layout_constraintTop_toBottomOf="@id/tvEmailLabel" />

            <View
                android:id="@+id/dividerEmail"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:background="@color/divider"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/etChangeEmail" />

            <TextView
                android:id="@+id/tvUsernameLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_marginTop="20dp"
                android:letterSpacing="0.08"
                android:text="@string/label_new_username"
                android:textColor="@color/colorPrimary"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvEmail" />

            <EditText
                android:id="@+id/etChangeUsername"
                android:layout_width="0dp"
                android:layout_height="35dp"
                android:layout_marginStart="5dp"
                android:layout_marginTop="8dp"
                android:background="@null"
                android:hint="@string/hint_new_username"
                android:inputType="textPersonName"
                android:paddingStart="0dp"
                android:paddingEnd="40dp"
                android:paddingBottom="8dp"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textMuted"
                android:textSize="15sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnChangeUsername"
                app:layout_constraintTop_toBottomOf="@id/tvUsernameLabel" />

            <View
                android:id="@+id/dividerUsername"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:background="@color/divider"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/etChangeUsername" />


            <TextView
                android:id="@+id/tvPasswordLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_marginTop="8dp"
                android:letterSpacing="0.08"
                android:text="@string/label_new_password"
                android:textColor="@color/colorPrimary"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"

                app:layout_constraintTop_toBottomOf="@id/dividerEmail"
                tools:ignore="HardcodedString" />

            <EditText
                android:id="@+id/etChangePassword"
                android:layout_width="0dp"
                android:layout_height="35dp"
                android:layout_marginStart="5dp"
                android:layout_marginTop="8dp"
                android:background="@null"
                android:hint="@string/hint_password_masked"
                android:inputType="textPassword"
                android:paddingStart="0dp"
                android:paddingEnd="40dp"
                android:paddingBottom="8dp"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textMuted"
                android:textSize="15sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnChangePassword"
                app:layout_constraintTop_toBottomOf="@id/tvPasswordLabel" />

            <ImageView
                android:id="@+id/ivPasswordToggle"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="4dp"
                android:clickable="true"
                android:focusable="true"
                android:scaleType="centerInside"
                android:src="@drawable/eye_icon"
                app:layout_constraintBottom_toBottomOf="@+id/etChangePassword"
                app:layout_constraintEnd_toEndOf="@+id/etChangePassword"
                app:tint="@color/iconTint" />

            <View
                android:id="@+id/dividerPassword"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:background="@color/divider"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/etChangePassword" />

            <Button
                android:id="@+id/btnChangeUsername"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="5dp"
                android:layout_marginBottom="7dp"
                android:backgroundTint="@color/buttonPrimary"
                android:letterSpacing="0.05"
                android:text="@string/btn_change"
                android:textColor="@color/textOnGold"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="@id/etChangeUsername"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="@+id/etChangeUsername"
                app:layout_constraintStart_toEndOf="@+id/etChangeUsername" />

            <Button
                android:id="@+id/btnChangeEmail"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="5dp"
                android:layout_marginBottom="7dp"
                android:backgroundTint="@color/buttonPrimary"
                android:letterSpacing="0.05"
                android:text="@string/btn_change"
                android:textColor="@color/textOnGold"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="@id/etChangeEmail"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="@id/etChangeEmail"
                app:layout_constraintStart_toEndOf="@+id/etChangeEmail" />

            <Button
                android:id="@+id/btnChangePassword"
                android:layout_width="105dp"
                android:layout_height="40dp"
                android:layout_marginStart="5dp"
                android:layout_marginBottom="7dp"
                android:backgroundTint="@color/buttonPrimary"
                android:letterSpacing="0.05"
                android:text="@string/btn_change"
                android:textColor="@color/textOnGold"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="@+id/etChangePassword"
                app:layout_constraintBottom_toBottomOf="@+id/etChangePassword"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/etChangePassword" />


        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        app:headerLayout="@layout/nav_header"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

</androidx.drawerlayout.widget.DrawerLayout>






