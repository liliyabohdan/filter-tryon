<!--
    activity_customer_home.xml — Layout for the Customer Home screen
    =================================================================
    Colors:  res/values/colors.xml
             (C:\Users\Admin\StudioProjects\305\app\src\main\res\values\colors.xml)

    STRUCTURE:
    - Top bar  : hamburger menu (left) + username (center)
    - Search bar below top bar
    - RecyclerView fills the rest — dynamically switches between
      1 column (items <= COLUMN_THRESHOLD) and 2 columns (items > COLUMN_THRESHOLD)

    COLUMN THRESHOLD (change this in your Activity):
        private val COLUMN_THRESHOLD = 5

    ADDING LOGIC LATER:
e    - Username from DB: find "TODO: Load username from DB"
    - Search logic    : find "TODO: Implement search logic"
    - Item click      : find "TODO: Navigate to item detail screen" (in your RecyclerView Adapter)
    - Load items      : find "TODO: Load items from DB and call updateGrid()"

    HOW THE DYNAMIC GRID WORKS (paste into CustomerHomeActivity):
    ─────────────────────────────────────────────────────────────
        private val COLUMN_THRESHOLD = 5   // ← change this value to adjust breakpoint

        private lateinit var recyclerView: RecyclerView
        private lateinit var gridLayoutManager: GridLayoutManager

        override fun onCreate(savedInstanceState: Bundle?) {
            super.onCreate(savedInstanceState)
            setContentView(R.layout.activity_customer_home)

            recyclerView = findViewById(R.id.rvItems)
            gridLayoutManager = GridLayoutManager(this, 1)
            recyclerView.layoutManager = gridLayoutManager

            // TODO: Load items from DB and call updateGrid()
            // updateGrid(itemList)
        }

        fun updateGrid(items: List<YourItemModel>) {
            val columns = if (items.size > COLUMN_THRESHOLD) 2 else 1
            gridLayoutManager.spanCount = columns
            recyclerView.adapter = YourAdapter(items, columns) // pass columns so adapter can size images
        }

    VIEW IDs:
    - @+id/btnMenu       — hamburger ImageButton (top-left)
    - @+id/tvUsername    — username TextView (top-center)
    - @+id/etSearch      — search EditText
    - @+id/ivSearch      — search icon ImageView
    - @+id/rvItems       — RecyclerView (the scrollable item grid)

    ─────────────────────────────────────────────────────────────
    RECYCLER ITEM LAYOUT: create res/layout/item_owned.xml
    (see comment at the bottom of this file).
    ─────────────────────────────────────────────────────────────
-->
<androidx.drawerlayout.widget.DrawerLayout android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/backgroundPrimary"
        tools:context=".CustomerHomeActivity"
        tools:ignore="HardcodedText">

        <!-- ══════════════════════════════════════
             TOP BAR
             ══════════════════════════════════════ -->

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:background="@null"
            android:src="@drawable/menu_icon"
            android:scaleType="centerInside"
            android:contentDescription="Menu"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/tvUsername"
            app:tint="@color/textPrimary" />

        <!--
            Username — pulled from DB.
            TODO: Load username from DB
            In your Activity:
                tvUsername = findViewById(R.id.tvUsername)
                tvUsername.text = currentUser.displayName  // replace with your DB call
        -->
        <TextView
            android:id="@+id/tvUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textColor="@color/textPrimary"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="Johanna Doe"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ══════════════════════════════════════
             SEARCH BAR
             ══════════════════════════════════════ -->

        <androidx.cardview.widget.CardView
            android:id="@+id/cardSearch"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/backgroundSecondary"
            app:layout_constraintTop_toBottomOf="@id/tvUsername"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!--
                    Search input.
                    TODO: Implement search logic
                    In your Activity:
                        etSearch = findViewById(R.id.etSearch)
                        etSearch.addTextChangedListener { query ->
                            // filter your item list and call updateGrid(filteredList)
                        }
                -->
                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:hint="@string/hint_search"
                    android:textColorHint="@color/textMuted"
                    android:textColor="@color/textPrimary"
                    android:textSize="14sp"
                    android:background="@null"
                    android:paddingStart="14dp"
                    android:paddingEnd="8dp"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:singleLine="true"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/ivSearch"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <!-- Search icon -->
                <ImageView
                    android:id="@+id/ivSearch"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/search_icon"
                    app:tint="@color/iconTint"
                    android:scaleType="centerInside"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- Gold accent line below search bar -->
        <View
            android:id="@+id/dividerSearch"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="8dp"
            android:background="@color/divider"
            app:layout_constraintTop_toBottomOf="@id/cardSearch"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ══════════════════════════════════════
             ITEMS GRID (RecyclerView)
             ══════════════════════════════════════
             GridLayoutManager column count is set programmatically in Activity.
             See "HOW THE DYNAMIC GRID WORKS" comment at the top of this file.

             Each item is rendered by res/layout/item_owned.xml (see bottom comment).
             Single-column list. Each card is rendered by item_shop.xml.
             TODO: Fetch market items from DB
             In your Activity:
                 RecyclerView rvShopItems = findViewById(R.id.rvShopItems);
                 rvShopItems.setLayoutManager(new LinearLayoutManager(this));
                 // fetch items from DB, then:
                 rvShopItems.setAdapter(new ShopAdapter(itemList));

        -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvItems"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp"
            android:clipToPadding="false"
            android:paddingBottom="16dp"
            tools:listitem="@layout/item_owned"
            app:layout_constraintTop_toBottomOf="@id/dividerSearch"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        app:headerLayout="@layout/nav_header"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        />

</androidx.drawerlayout.widget.DrawerLayout>


