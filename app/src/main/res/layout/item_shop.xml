<?xml version="1.0" encoding="utf-8"?>
<!--
    item_shop.xml — single card in the Shop list
    Used by: RecyclerView (@+id/rvShopItems) in activity_shop.xml
    Adapter: ShopAdapter.java
    IDs: @+id/ivItemImage, @+id/tvItemName, @+id/btnView, @+id/rbRating, @+id/tvRatingValue
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="16dp"
    android:background="@color/backgroundPrimary">

    <ImageView
        android:id="@+id/ivItemImage"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:scaleType="centerCrop"
        android:background="@color/backgroundSecondary"
        android:contentDescription="Item image"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvItemName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/textPrimary"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/ivItemImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnView"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="@string/btn_view"
        android:textColor="@color/textOnGold"
        android:textSize="13sp"
        android:backgroundTint="@color/buttonPrimary"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvItemName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <RatingBar
        android:id="@+id/rbRating"
        style="?android:attr/ratingBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:numStars="5"
        android:stepSize="0.5"
        android:isIndicator="true"
        android:progressTint="@color/colorPrimary"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
    <!-- isIndicator set to true to not have the user change the review -->
    <!-- Numeric rating tooltip — hidden by default, shown when user taps the RatingBar -->
    <TextView
        android:id="@+id/tvRatingValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@color/backgroundDark"
        android:textColor="@color/textOnDark"
        android:textSize="12sp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone"
        android:text="@string/placeholder_rating_numeric"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/rbRating"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
