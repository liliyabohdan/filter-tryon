<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_creator_item_card.xml — Mask detail screen for creators
    =================================================================
    Colors:  res/values/colors.xml
             (C:\Users\Admin\StudioProjects\305\app\src\main\res\values\colors.xml)

    STRUCTURE:
    - Top bar           : hamburger menu (left) + username (center)
    - Mask name         : bold heading
    - Main image        : large square, swaps when thumbnail tapped
    - 4 Thumbnails      : vertical strip on the right of main image
    - Edit button       : opens EditMaskActivity (pre-filled with existing data)
    - Recent reviews    : collapsible row → opens all-reviews popup dialog
    - Purchase metrics  : collapsible row → opens metrics popup dialog with graphs

    ADDING LOGIC LATER:
    - Hamburger menu         : find "TODO: Open navigation drawer / menu"
    - Username from DB       : find "TODO: Load username from DB"
    - Load mask data         : find "TODO: Load mask data from DB"
    - Thumbnail swap         : find "TODO: Swap main image with tapped thumbnail"
    - Edit button            : find "TODO: Navigate to EditMaskActivity"
    - Recent reviews row     : find "TODO: Open all reviews dialog"
    - Purchase metrics row   : find "TODO: Open purchase metrics dialog"

    THUMBNAIL SWAP LOGIC (paste into CreatorItemCardActivity):
    ──────────────────────────────────────────────────────────
        private void swapMainImage(ImageView tappedThumb) {
            Drawable mainDrawable = ivMainImage.getDrawable();
            Drawable thumbDrawable = tappedThumb.getDrawable();
            ivMainImage.setImageDrawable(thumbDrawable);
            tappedThumb.setImageDrawable(mainDrawable);
        }
        ivThumb1.setOnClickListener(v -> swapMainImage(ivThumb1));
        ivThumb2.setOnClickListener(v -> swapMainImage(ivThumb2));
        ivThumb3.setOnClickListener(v -> swapMainImage(ivThumb3));
        ivThumb4.setOnClickListener(v -> swapMainImage(ivThumb4));

    RELATED FILES:
    - res/layout/item_review.xml                      — reused from customer side
    - res/layout/fragment_all_reviews_dialog.xml      — all reviews popup
    - res/layout/fragment_purchase_metrics_dialog.xml — metrics popup with graphs

    VIEW IDs:
    - @+id/btnMenu           — hamburger ImageButton
    - @+id/tvUsername        — username
    - @+id/tvMaskName        — mask name heading
    - @+id/ivMainImage       — large main image
    - @+id/ivThumb1..4       — four thumbnail ImageViews
    - @+id/btnEdit           — Edit button → EditMaskActivity
    - @+id/rowReviews        — tappable row → opens all reviews dialog
    - @+id/rowMetrics        — tappable row → opens purchase metrics dialog
-->

<androidx.drawerlayout.widget.DrawerLayout
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundPrimary"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp"
        tools:context=".CreatorItemCardActivity">

        <!-- ══════════════════════════════════════
             TOP BAR
             ══════════════════════════════════════ -->

        <!--
            TODO: Open navigation drawer / menu
            ImageButton btnMenu = findViewById(R.id.btnMenu);
            btnMenu.setOnClickListener(v -> { ... });
        -->
        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:background="@null"
            android:src="@drawable/menu_icon"
            app:tint="@color/textPrimary"
            android:scaleType="centerInside"
            android:contentDescription="Menu"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/tvUsername" />

        <!--
            TODO: Load username from DB
            tvUsername.setText(currentUser.getDisplayName());
        -->
        <TextView
            android:id="@+id/tvUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/placeholder_username"
            android:textColor="@color/textPrimary"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="Johanna Doe"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Gold underline below top bar -->
        <View
            android:id="@+id/dividerTop"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="8dp"
            android:background="@color/divider"
            app:layout_constraintTop_toBottomOf="@id/tvUsername"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ══════════════════════════════════════
             MASK NAME
             ══════════════════════════════════════ -->

        <!--
            TODO: Load mask data from DB
            tvMaskName.setText(mask.getName());
        -->
        <TextView
            android:id="@+id/tvMaskName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_mask_name"
            android:textColor="@color/textPrimary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            tools:text="Mask 1"
            app:layout_constraintTop_toBottomOf="@id/dividerTop"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- ══════════════════════════════════════
             MAIN IMAGE + 4 THUMBNAILS
             ══════════════════════════════════════ -->

        <!--
            Large main image.
            TODO: Load mask data from DB
            Glide.with(this).load(mask.getMainImageUrl()).into(ivMainImage);
        -->
        <ImageView
            android:id="@+id/ivMainImage"
            android:layout_width="0dp"
            android:layout_height="240dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="8dp"
            android:scaleType="centerCrop"
            android:background="@color/backgroundSecondary"
            android:contentDescription="Main mask image"
            app:layout_constraintTop_toBottomOf="@id/tvMaskName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/llThumbnails" />

        <!--
            Vertical strip of 4 thumbnails.
            TODO: Swap main image with tapped thumbnail
            See THUMBNAIL SWAP LOGIC in header.
        -->
        <LinearLayout
            android:id="@+id/llThumbnails"
            android:layout_width="64dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvMaskName"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/ivMainImage">

            <ImageView
                android:id="@+id/ivThumb1"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="4dp"
                android:scaleType="centerCrop"
                android:background="@color/backgroundSecondary"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Thumbnail 1" />

            <ImageView
                android:id="@+id/ivThumb2"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="4dp"
                android:scaleType="centerCrop"
                android:background="@color/backgroundSecondary"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Thumbnail 2" />

            <ImageView
                android:id="@+id/ivThumb3"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="4dp"
                android:scaleType="centerCrop"
                android:background="@color/backgroundSecondary"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Thumbnail 3" />

            <ImageView
                android:id="@+id/ivThumb4"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scaleType="centerCrop"
                android:background="@color/backgroundSecondary"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Thumbnail 4" />

        </LinearLayout>

        <!-- ══════════════════════════════════════
             EDIT BUTTON
             ══════════════════════════════════════ -->

        <!--
            TODO: Navigate to EditMaskActivity
            In your Activity:
                btnEdit = findViewById(R.id.btnEdit);
                btnEdit.setOnClickListener(v -> {
                    Intent intent = new Intent(this, EditMaskActivity.class);
                    intent.putExtra("MASK_ID", mask.getId());
                    startActivity(intent);
                });
        -->
        <Button
            android:id="@+id/btnEdit"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:text="@string/btn_edit"
            android:textColor="@color/textOnGold"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="@color/buttonPrimary"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/ivMainImage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ══════════════════════════════════════
             COLLAPSIBLE ROWS
             ══════════════════════════════════════ -->

        <!-- Divider above rows -->
        <View
            android:id="@+id/dividerRows"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/dividerLight"
            android:layout_marginTop="24dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toBottomOf="@id/btnEdit"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!--
            "Recent reviews" tappable row.
            TODO: Open all reviews dialog
            In your Activity:
                rowReviews = findViewById(R.id.rowReviews);
                rowReviews.setOnClickListener(v -> {
                    AllReviewsDialogFragment dialog = new AllReviewsDialogFragment();
                    dialog.show(getSupportFragmentManager(), "AllReviewsDialog");
                });
        -->
        <LinearLayout
            android:id="@+id/rowReviews"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            app:layout_constraintTop_toBottomOf="@id/dividerRows"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/recent_reviews"
                android:textColor="@color/textPrimary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivReviewsChevron"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/chevron_icon"
                app:tint="@color/textSecondary"
                android:scaleType="centerInside"
                android:contentDescription="Expand reviews" />

        </LinearLayout>

        <!-- Divider between rows -->
        <View
            android:id="@+id/dividerBetweenRows"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/dividerLight"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toBottomOf="@id/rowReviews"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!--
            "Purchase metrics" tappable row.
            TODO: Open purchase metrics dialog
            In your Activity:
                rowMetrics = findViewById(R.id.rowMetrics);
                rowMetrics.setOnClickListener(v -> {
                    PurchaseMetricsDialogFragment dialog = new PurchaseMetricsDialogFragment();
                    dialog.show(getSupportFragmentManager(), "PurchaseMetricsDialog");
                });
        -->
        <LinearLayout
            android:id="@+id/rowMetrics"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            app:layout_constraintTop_toBottomOf="@id/dividerBetweenRows"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/purchase_metrics"
                android:textColor="@color/textPrimary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivMetricsChevron"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/chevron_icon"
                app:tint="@color/textSecondary"
                android:scaleType="centerInside"
                android:contentDescription="Expand metrics" />

        </LinearLayout>

        <!-- Divider below rows -->
        <View
            android:id="@+id/dividerBottom"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/dividerLight"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toBottomOf="@id/rowMetrics"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>

<com.google.android.material.navigation.NavigationView
    android:id="@+id/navigationView"
    app:headerLayout="@layout/nav_header"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>