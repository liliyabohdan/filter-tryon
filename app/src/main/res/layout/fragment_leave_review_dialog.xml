<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/backgroundPrimary">

    <!-- Dialog title -->
    <TextView
        android:id="@+id/tvDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/leave_review"
        android:textColor="@color/textPrimary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/leave_review_subtitle"
        android:textColor="@color/textSecondary"
        android:textSize="13sp"
        android:layout_marginBottom="20dp" />

    <!-- Star rating input -->
    <TextView
        android:id="@+id/tvRatingHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_your_rating"
        android:textColor="@color/colorPrimary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:layout_marginBottom="6dp" />

    <RatingBar
        android:id="@+id/rbUserRating"
        style="?android:attr/ratingBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:numStars="5"
        android:stepSize="0.5"
        android:rating="0"
        android:progressTint="@color/colorPrimary"
        android:layout_marginBottom="20dp" />

    <!-- Review comment label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_your_review"
        android:textColor="@color/colorPrimary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:layout_marginBottom="6dp" />

    <!--
        Multi-line comment input.
        Wrapped in a CardView for a clean bordered look.
    -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/backgroundSecondary"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_marginBottom="24dp">

        <EditText
            android:id="@+id/etReviewComment"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:hint="@string/hint_review_comment"
            android:textColorHint="@color/textMuted"
            android:textColor="@color/textPrimary"
            android:textSize="14sp"
            android:background="@null"
            android:padding="12dp"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:lines="4"
            android:maxLines="6"
            android:scrollbars="vertical" />

    </androidx.cardview.widget.CardView>

    <!-- Cancel + Submit buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Cancel — dismisses without saving -->
        <Button
            android:id="@+id/btnCancelReview"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/btn_cancel"
            android:textColor="@color/textPrimary"
            android:backgroundTint="@color/buttonDisabled"
            android:layout_marginEnd="8dp" />

        <!-- Submit — saves review to DB -->
        <Button
            android:id="@+id/btnSubmitReview"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/btn_submit"
            android:textColor="@color/textOnGold"
            android:backgroundTint="@color/buttonPrimary"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</LinearLayout>